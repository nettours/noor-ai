# ═══════════════════════════════════════════════════════
#  Noor AI — Frontend Environment (frontend/.env.local)
#  انسخ هذا الملف إلى .env.local واملأ القيم
#  كل متغيّرات الواجهة تبدأ بـ NEXT_PUBLIC_ (تظهر في المتصفّح)
# ═══════════════════════════════════════════════════════

# ── رابط الـ Backend API (مطلوب) ────────────────────────
# ⚠️ يجب أن ينتهي بـ /api
# محلياً:
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000/api
# في الإنتاج (مثال خادمك على Railway):
# NEXT_PUBLIC_BACKEND_URL=https://noor-ai-production.up.railway.app/api

# ── رابط التطبيق — يُستعمل في روابط المشاركة (مُستحسن) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
# في الإنتاج:
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── رابط الموقع — يُستعمل في SEO/Sitemap/Robots (مُستحسن) ─
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# في الإنتاج:
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
