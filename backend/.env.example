# ═══════════════════════════════════════════════════════
#  Noor AI — Backend Environment (backend/.env)
#  انسخ هذا الملف إلى .env واملأ القيم الحقيقية
#  هذه فقط المتغيّرات التي يقرأها backend/src/server.ts فعلاً
# ═══════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
# المنفذ. على Railway يُحقَن تلقائياً (لا داعي لضبطه هناك).
PORT=4000

# ── Security (مطلوب) ────────────────────────────────────
# مفتاح توقيع JWT. ضع نصاً عشوائياً طويلاً (32 حرفاً فأكثر).
# توليد سريع:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ضع-هنا-نص-عشوائي-طويل-جداً

# ── Database — MongoDB (مطلوب للحفظ الدائم) ─────────────
# نستعمل MongoDB (وليس PostgreSQL). يقرأ DATABASE_URL أوّلاً ثم MONGODB_URI.
# احصل على رابط مجاني من MongoDB Atlas: https://www.mongodb.com/atlas
# مثال: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/noor
# إن تُرك فارغاً يعمل الخادم بالذاكرة فقط (بيانات مؤقّتة تُمحى عند إعادة التشغيل).
DATABASE_URL=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/noor

# ── AI — Google Gemini (مطلوب للمساعد والبوتات) ─────────
# محرّك "نور Scholar" وردود البوتات. مفتاح مجاني من:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key

# ── Admin Panel (اختياري) ───────────────────────────────
# بريد المستخدم الذي يملك صلاحية الدخول إلى /admin.
ADMIN_EMAIL=you@example.com

# ── Cloudinary — رفع الصور/الفيديو في الـ Feed (اختياري) ─
# من لوحة Cloudinary: Cloud name + Unsigned upload preset.
# إن تُركا فارغين يبقى الـ Feed نصّياً فقط (لا رفع وسائط).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# ── Web Push — تنبيهات الصلاة (اختياري) ─────────────────
# ولّد مفاتيح صحيحة بـ:  npx web-push generate-vapid-keys
# ⚠️ لا تضع قيماً نموذجية وهمية هنا — مفاتيح غير صالحة تعطّل الـ push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@snetprodz.com
