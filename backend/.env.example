# ═══════════════════════════════════════════════════════
# نسخ هذا الملف إلى .env واملأ القيم الحقيقية
# Copy to .env and fill with real values
# (هذه هي المتغيّرات المستعملة فعلاً في src/server.ts)
# ═══════════════════════════════════════════════════════

# Server
PORT=4000
NODE_ENV=production

# Security (غيّر هذه القيمة! تُستعمل لتوقيع JWT)
JWT_SECRET=ضع-هنا-نص-عشوائي-طويل-جداً-2025-noor-ai

# Database — MongoDB (يقرأ DATABASE_URL أوّلاً ثم MONGODB_URI)
# بدون قيمة: التخزين في الذاكرة فقط (مؤقّت، يُفقد عند إعادة التشغيل)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/noor

# Gemini AI (محرّك المساعد الذكي / Noor Scholar — البوتات)
GEMINI_API_KEY=your-gemini-key

# Admin (بريد المستخدم الذي يملك صلاحية لوحة الأدمن)
ADMIN_EMAIL=admin@example.com

# Web Push — تنبيهات الصلاة (ولّدها بـ: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@snetprodz.com

# Cloudinary — رفع الصور/الفيديو (إعدادات client-side للرفع المباشر)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
