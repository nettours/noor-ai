# ═══════════════════════════════════════════════════════
# نسخ هذا الملف إلى .env واملأ القيم الحقيقية
# Copy to .env and fill with real values
# ═══════════════════════════════════════════════════════

# Server
PORT=4000
NODE_ENV=production

# Security (غيّر هذه القيم!)
JWT_SECRET=ضع-هنا-نص-عشوائي-طويل-جداً-2025-noor-ai
JWT_REFRESH_SECRET=ضع-هنا-نص-عشوائي-آخر-للـ-refresh-tokens

# Frontend URL (للسماح في CORS)
FRONTEND_URL=https://your-app.vercel.app

# Anthropic API Key (للمساعد الذكي)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# Database (PostgreSQL على Railway - يُملأ تلقائياً)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (اختياري - للأداء)
REDIS_URL=redis://default:pass@host:6379

# Gemini AI (محرّك المساعد الذكي / Noor Scholar)
GEMINI_API_KEY=your-gemini-key

# Web Push — تنبيهات الصلاة (ولّدها بـ: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@snetprodz.com
